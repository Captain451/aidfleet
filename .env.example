APP_ENV=development
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aidfleet_db
DB_USER=root
DB_PASS=

SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_AUTH=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="AidFleet Emergency Response System"

UPLOAD_DRIVER_DOCS_DIR=uploads/driver_docs
UPLOAD_MAX_SIZE_MB=20

# Africa's Talking SMS - https://account.africastalking.com
#
# SANDBOX (development):
#   SMS_USERNAME=sandbox
#   SMS_API_KEY=<API key from Sandbox app → Settings → API Key>
#   SMS_SENDER_ID=          (leave empty; sandbox ignores custom sender IDs)
#   Test numbers must be added in the Sandbox dashboard.
#
# LIVE (production):
#   1. Open your live app on account.africastalking.com (NOT sandbox)
#   2. Settings -> API Key -> Generate (production key for that app)
#   3. Top up SMS wallet for Kenya
#   4. Set SMS_USERNAME + SMS_API_KEY from that live app
#   5. Leave SMS_SENDER_ID empty unless Africa's Talking has approved a sender ID,
#      shortcode, or alphanumeric ID for this app.
#   Username + API key must belong to the same app.
#
SMS_ENABLED=false
SMS_USERNAME=sandbox
SMS_API_KEY=your-africastalking-api-key
# Optional. Leave empty if you have not purchased/registered one.
SMS_SENDER_ID=
SMS_SSL_VERIFY=false
SMS_ENQUEUE=false

GOOGLE_MAPS_API_KEY=your-google-maps-api-key
